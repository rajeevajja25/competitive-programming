#include <iostream>
#include <vector>
using namespace std;

int main() {
    int t;
    cin >> t;

    while (t--) {
        int n;
        cin >> n;

        vector<long long> a(n);

        for (int i = 0; i < n; i++) {
            cin >> a[i];
        }

        long long ans = 0;
        long long currMax = a[0];

        for (int i = 1; i < n; i++) {
            if ((a[i] > 0 && a[i - 1] > 0) ||
                (a[i] < 0 && a[i - 1] < 0)) {

                currMax = max(currMax, a[i]);
            }
            else {
                ans += currMax;
                currMax = a[i];
            }
        }

        ans += currMax;

        cout << ans << '\n';
    }
}

#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int main() {
    int t;
    cin >> t;
    while (t--) {
        int n;
        cin >> n;
        vector<int> w(n);

        for (int i = 0; i < n; i++) {
            cin >> w[i];
        }
        sort(w.begin(), w.end());

        int ans = 0;
        for (int s = 2; s <= 100; s++) {
            int l = 0;
            int r = n - 1;
            int teams = 0;
            while (l < r) {
                int cur = w[l] + w[r];
                if (cur == s) {
                    teams++;
                    l++;
                    r--;
                }
                else if (cur < s) {
                    l++;
                }
                else {
                    r--;
                }
            }

            ans = max(ans, teams);
        }

        cout << ans << '\n';
    }

    return 0;
}

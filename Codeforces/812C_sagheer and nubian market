#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    int n;
    long long S;
    cin >> n >> S;
    vector<long long> a(n);
    for (int i = 0; i < n; i++)
        cin >> a[i];
    auto check = [&](int k) {
        vector<long long> cost(n);
        for (int i = 0; i < n; i++)
            cost[i] = a[i] + 1LL * (i + 1) * k;
        sort(cost.begin(), cost.end());
        long long sum = 0;
        for (int i = 0; i < k; i++)
            sum += cost[i];
        return sum;
    };

    int lo = 0, hi = n;
    int bestK = 0;
    long long bestCost = 0;

    while (lo <= hi) {
        int mid = (lo + hi) / 2;
        long long curCost = check(mid);
        if (curCost <= S) {
            bestK = mid;
            bestCost = curCost;
            lo = mid + 1;
        } else {
            hi = mid - 1;
        }
    }

    cout << bestK << ' ' << bestCost << '\n';
}
